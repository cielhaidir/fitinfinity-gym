    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "postinstall": "prisma generate",
    "build:info": "next build --profile",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "create-profile-dir": "tsx scripts/create-profile-dir.ts"
