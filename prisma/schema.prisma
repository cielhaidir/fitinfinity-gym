generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum EnrollmentStatus {
    NOT_YET
    PENDING
    ENROLLED
    FAILED
}

enum RoleType {
    EMPLOYEE
    MEMBER
}

enum PaymentStatus {
    SUCCESS
    PENDING
    FAILED
    EXPIRED
    CANCELED
    CHALLENGED
    REFUNDED
    SETTLED
}

enum VoucherType {
    REFERRAL
    GENERAL
}

enum DiscountType {
    PERCENT
    CASH
}

enum PaymentValidationStatus {
    WAITING
    ACCEPTED
    DECLINED
}

enum FCMemberStatus {
    new
    contacted
    follow_up
    interested
    not_interested
    pending
    scheduled
    converted
    rejected
    inactive
}

enum FlowType {
    income
    outcome
    both
}

enum Gender {
    MALE
    FEMALE
    OTHER
}

enum SessionStatus {
    ENDED
    NOT_YET
    CANCELED
    ONGOING
}

model File {
    id           String   @id @default(uuid())
    bucket       String
    fileName     String   @unique
    originalName String
    createdAt    DateTime @default(now())
    size         Int
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id                 String            @id @default(cuid())
    name               String?
    email              String?           @unique
    emailVerified      DateTime?
    password           String?
    address            String?
    phone              String?
    birthDate          DateTime?
    idNumber           String?
    image              String?
    resetToken         String?           @unique
    resetTokenExpiry   DateTime?
    roles              Role[]
    memberships        Membership[]      @relation("MembershipToUser")
    personalTrainer    PersonalTrainer[] @relation("PersonalTrainerToUser")
    fc                 FC[]             @relation("FCToUser")
    accounts           Account[]
    sessions           Session[]
    posts              Post[]
    createdBy          String?
    createdUsers       User[]            @relation("UserCreatedBy")
    creator            User?             @relation("UserCreatedBy", fields: [createdBy], references: [id])
    createdMemberships Membership[]      @relation("MembershipCreator")
    createdFCs         FC[]             @relation("UserCreatedBy")
    createdAt          DateTime          @default(now())
    updatedAt          DateTime          @updatedAt
    point              Int               @default(0)
    employee           Employee?         @relation("EmployeeToUser")
    memberRewards      MemberReward[]
    voucherClaims      VoucherClaim[]
    height             Float?
    weight             Float?
    gender             Gender?
    posSales           POSSale[]
}

model Class {
    id                String             @id @default(cuid())
    name              String
    limit             Int?
    trainerId         String
    schedule          DateTime
    duration          Int
    price             Float              @default(0)
    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt
    trainer           PersonalTrainer    @relation(fields: [trainerId], references: [id])
    registeredMembers ClassMember[]
    waitingList       ClassWaitingList[]
}

model ClassMember {
    id       String     @id @default(cuid())
    classId  String
    memberId String
    class    Class      @relation(fields: [classId], references: [id])
    member   Membership @relation(fields: [memberId], references: [id])
    joinedAt DateTime   @default(now())
}

model ClassWaitingList {
    id       String     @id @default(cuid())
    classId  String
    memberId String
    class    Class      @relation(fields: [classId], references: [id])
    member   Membership @relation(fields: [memberId], references: [id])
    joinedAt DateTime   @default(now())
}

model Membership {
    id                String             @id @default(cuid())
    userId            String             @unique
    user              User               @relation("MembershipToUser", fields: [userId], references: [id])
    registerDate      DateTime
    rfidNumber        String?
    isActive          Boolean            @default(false)
    createdBy         String?
    fcId              String?
    fc                FC?                @relation(fields: [fcId], references: [id])
    revokedAt         DateTime?
    creator           User?              @relation("MembershipCreator", fields: [createdBy], references: [id])
    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt
    subscriptions     Subscription[]
    registeredClasses ClassMember[]
    waitingClasses    ClassWaitingList[]
    trainerSessions   TrainerSession[]
    paymentValidations PaymentValidation[]
    attendanceMembers AttendanceMember[] @relation("AttendanceMemberToMembership")
}

model Role {
    id          String           @id @default(cuid())
    name        String           @unique
    permissions RolePermission[]
    users       User[]
}

model Permission {
    id    String           @id @default(cuid())
    name  String           @unique
    roles RolePermission[]
}

model RolePermission {
    roleId       String
    permissionId String
    role         Role       @relation(fields: [roleId], references: [id])
    permission   Permission @relation(fields: [permissionId], references: [id])

    @@id([roleId, permissionId])
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model Subscription {
    id                String           @id @default(cuid())
    memberId          String
    trainerId         String?
    packageId         String
    member            Membership       @relation(fields: [memberId], references: [id])
    package           Package          @relation(fields: [packageId], references: [id])
    trainer           PersonalTrainer? @relation(fields: [trainerId], references: [id])
    startDate         DateTime
    endDate           DateTime?
    remainingSessions Int?
    isActive          Boolean          @default(false)
    payments          Payment[]
}

model Payment {
    id             String        @id @default(cuid())
    subscriptionId String
    subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
    status         PaymentStatus
    method         String
    totalPayment   Int
    token          String?       // Dedicated field for payment gateway token
    tokenExpiry    DateTime?     // When the token expires
    orderReference String?       @unique  // Used to track payments with the gateway
    gatewayResponse Json?        // Store the complete gateway response
    paymentUrl     String?       // URL to payment page (if applicable)
    paidAt         DateTime?     // When the payment was completed
    createdAt      DateTime      @default(now())
    updatedAt      DateTime      @default(now())
}

model PersonalTrainer {
    id          String   @id @default(cuid())
    userId      String   @unique
    description String?
    expertise   String?
    image       String?
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    class       Class[]

    user          User             @relation("PersonalTrainerToUser", fields: [userId], references: [id])
    subscriptions Subscription[]
    sessions      TrainerSession[]
    paymentValidations PaymentValidation[]

}

enum MembershipStatus {
    ACTIVE
    EXPIRED
    REVOKED
}

model Post {
    id          Int      @id @default(autoincrement())
    name        String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    createdById String

    createdBy User @relation(fields: [createdById], references: [id])

    @@index([name])
}

model Package {
    id           String         @id @default(cuid())
    name         String
    description  String?
    price        Float
    point        Int            @default(0) // Points yang akan didapat user ketika membeli paket
    isActive     Boolean        @default(true)
    type         PackageType
    sessions     Int? // only for PERSONAL_TRAINER type
    day          Int? // only for GYM_MEMBERSHIP type
    createdAt    DateTime       @default(now())
    updatedAt    DateTime       @updatedAt
    subscription Subscription[]
    paymentValidations PaymentValidation[]
}

enum PackageType {
    GYM_MEMBERSHIP
    PERSONAL_TRAINER
}

model TrainerSession {
    id          String   @id @default(cuid())
    trainerId   String
    memberId    String
    date        DateTime
    startTime   DateTime
    endTime     DateTime
    description String?
    status      String   @default("NOT_YET")
    exerciseResult String? // Optional path to the uploaded exercise result file
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    trainer     PersonalTrainer @relation(fields: [trainerId], references: [id])
    member      Membership @relation(fields: [memberId], references: [id])
}

model Voucher {
    id           String         @id @default(cuid())
    name         String
    maxClaim     Int // Maximum number of times this voucher can be claimed
    type         VoucherType
    discountType DiscountType
    referralCode String? // Optional referral code, only used for REFERRAL type
    amount       Int // Amount of discount (in percentage or cash value)
    isActive     Boolean        @default(true)
    expiryDate   DateTime? // Optional expiry date for the voucher
    createdAt    DateTime       @default(now())
    updatedAt    DateTime       @updatedAt
    claims       VoucherClaim[]

    @@index([referralCode])
    @@index([type])
}

model VoucherClaim {
    id        String   @id @default(cuid())
    memberId  String
    voucherId String
    claimedAt DateTime @default(now())
    member    User     @relation(fields: [memberId], references: [id])
    voucher   Voucher  @relation(fields: [voucherId], references: [id])

    @@index([memberId])
    @@index([voucherId])
}

model PaymentValidation {
    id             String                  @id @default(cuid())
    memberId       String
    packageId      String
    trainerId      String?
    fcId           String?
    subsType       String // "gym" or "trainer"
    duration       Int    // days for gym, sessions for trainer
    sessions       Int?   // number of sessions for trainer package
    totalPayment   Float
    paymentMethod  String // e.g., "direct_payment"
    filePath       String? // Path to the uploaded proof of payment
    paymentStatus  PaymentValidationStatus @default(WAITING)
    createdAt      DateTime                @default(now())
    updatedAt      DateTime                @updatedAt
    balanceId      Int?                    
    
    balanceAccount BalanceAccount?         @relation(fields: [balanceId], references: [id], onDelete: SetNull)
    member         Membership              @relation(fields: [memberId], references: [id])
    package        Package                 @relation(fields: [packageId], references: [id])
    trainer        PersonalTrainer?        @relation(fields: [trainerId], references: [id])
    fc             FC?                     @relation(fields: [fcId], references: [id])
    @@index([memberId])
    @@index([paymentStatus])
}

model MemberReward {
    id        String   @id @default(cuid())
    memberId  String
    rewardId  String
    claimedAt DateTime @default(now())
    member    User     @relation(fields: [memberId], references: [id])
    reward    Reward   @relation(fields: [rewardId], references: [id])

    @@index([memberId])
    @@index([rewardId])
}

model Reward {
    id            String         @id @default(cuid())
    name          String
    iconName      String
    price         Int
    stock         Int
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt
    memberRewards MemberReward[]
}

model Employee {
    id              String           @id @default(cuid())
    userId          String           @unique
    position        String?
    department      String?
    image           String?
    fingerprintId   Int?            @unique
    rfidTag         String?         @unique
    isActive        Boolean         @default(true)
    enrollmentStatus EnrollmentStatus?
    deviceId        String?         // For tracking which device is enrolling
    createdAt       DateTime        @default(now())
    updatedAt       DateTime        @updatedAt
    attendances Attendance[]

    user User @relation("EmployeeToUser", fields: [userId], references: [id])
}

model Attendance {
    id         String    @id @default(cuid())
    employeeId String
    checkIn    DateTime
    checkOut   DateTime?
    deviceId  String? // Optional device ID for attendance tracking
    date       DateTime  @default(now())
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt

    employee Employee @relation(fields: [employeeId], references: [id])

    @@index([date])
    @@index([employeeId])
}

model BalanceAccount {
    id               Int           @id @default(autoincrement())
    name             String
    account_number   String
    initialBalance   Float         @default(0)
    lastBalance      Float         @default(0)
    totalTransaction Float         @default(0)
    bankTransactions Transaction[] @relation("BankTransactions")
    paymentValidations PaymentValidation[]
    posSales         POSSale[]
}

model ChartAccount {
    id                  Int           @id @default(autoincrement())
    reff                String
    name                String
    type                String
    flow                FlowType
    accountTransactions Transaction[] @relation("AccountTransactions")
}

model Transaction {
    id                 Int       @id @default(autoincrement())
    bank_id            Int
    account_id         Int
    type               String
    file               String
    description        String
    transaction_date   DateTime
    transaction_number String
    amount             Float
    closed_at          DateTime?

    // Relations
    bank    BalanceAccount @relation("BankTransactions", fields: [bank_id], references: [id])
    account ChartAccount   @relation("AccountTransactions", fields: [account_id], references: [id])
}

model AttendanceMember {
    id        String     @id @default(cuid())
    memberId  String
    checkin   DateTime

    member    Membership @relation("AttendanceMemberToMembership", fields: [memberId], references: [id])

    @@index([memberId])
}

model FC {
    id          String   @id @default(cuid())
    userId      String   @unique
    referralCode String? @unique
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    createdBy   String?

    user          User             @relation("FCToUser", fields: [userId], references: [id])
    creator       User?            @relation("UserCreatedBy", fields: [createdBy], references: [id])
    paymentValidations PaymentValidation[]
    memberships   Membership[]
    fc_members    FcMember[]
}

// Email Configuration Models
enum EmailType {
    MEMBERSHIP_CONFIRMATION
    PAYMENT_RECEIPT
    PASSWORD_RESET
    SUBSCRIPTION_EXPIRY
    TRAINER_SESSION_REMINDER
}

enum EmailStatus {
    PENDING
    SENT
    FAILED
    BOUNCED
}

model EmailConfig {
    id          String   @id @default(cuid())
    name        String   @unique // e.g., "primary", "backup"
    host        String
    port        Int
    username    String
    password    String   // encrypted
    fromEmail   String
    fromName    String
    useTLS      Boolean  @default(true)
    useSSL      Boolean  @default(false)
    isActive    Boolean  @default(false)
    isDefault   Boolean  @default(false)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([isActive])
    @@index([isDefault])
}

model EmailTemplate {
    id          String   @id @default(cuid())
    name        String   @unique
    type        EmailType
    subject     String
    htmlContent String   @db.Text
    textContent String?  @db.Text
    variables   Json     // Available template variables
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    emailLogs   EmailLog[]

    @@index([type])
    @@index([isActive])
}

model FcMember {
    id           String   @id @default(cuid())
    fc_id        String
    member_name  String
    member_phone String
    address      String
    status       FCMemberStatus
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
    fc           FC       @relation(fields: [fc_id], references: [id])
    @@index([fc_id])
}

model EmailLog {
    id          String      @id @default(cuid())
    to          String
    subject     String
    templateId  String?
    status      EmailStatus @default(PENDING)
    errorMessage String?
    sentAt      DateTime?
    createdAt   DateTime    @default(now())
    
    template    EmailTemplate? @relation(fields: [templateId], references: [id])

    @@index([status])
    @@index([createdAt])
    @@index([to])
}

model Config {
    id        String   @id @default(cuid())
    key       String   @unique
    value     String
    category  String?  // Optional category for organizing configs
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([key])
    @@index([category])
}


enum DeviceStatus {
    ONLINE
    OFFLINE
    ERROR
    MAINTENANCE
}

model Device {
    id                 String       @id @default(cuid())
    name               String
    type               String       @default("ESP32") // Device type
    accessKey          String
    status             DeviceStatus @default(OFFLINE)
    isActive           Boolean      @default(true)
    lastSeen           DateTime?
    
    // WiFi Configuration
    configuredWifi     String?      // Currently configured WiFi SSID
    wifiStatus         String?      // WiFi connection status
    availableNetworks  String?      @db.Text // JSON string of available networks
    lastNetworkScan    DateTime?
    lastConfigured     DateTime?
    
    // Firmware Management
    firmwareVersion    String?      // Current firmware version
    availableFirmware  String?      // Available firmware version
    lastFirmwareUpdate DateTime?
    
    // Device Health
    batteryLevel       Int?         // Battery percentage (if applicable)
    signalStrength     Int?         // WiFi signal strength
    uptime             Int?         // Device uptime in seconds
    temperature        Float?       // Device temperature
    errorMessage       String?      // Last error message
    errorCount         Int          @default(0)
    
    // MQTT Configuration
    mqttConnected      Boolean      @default(false)
    lastMqttMessage    DateTime?
    mqttClientId       String?
    
    createdAt          DateTime     @default(now())
    updatedAt          DateTime     @updatedAt
    
    @@index([status])
    @@index([lastSeen])
}

// POS Models for Additional Items (Drinks, Snacks, etc.)
model POSCategory {
    id          String      @id @default(cuid())
    name        String      @unique
    description String?
    isActive    Boolean     @default(true)
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt
    
    items       POSItem[]
}

model POSItem {
    id          String      @id @default(cuid())
    name        String
    description String?
    price       Float
    cost        Float?      @default(0)
    stock       Int         @default(0)
    minStock    Int?        @default(0)
    categoryId  String
    isActive    Boolean     @default(true)
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt
    
    category    POSCategory @relation(fields: [categoryId], references: [id])
    saleItems   POSSaleItem[]
    
    @@index([categoryId])
    @@index([name])
}

model POSSale {
    id            String        @id @default(cuid())
    saleNumber    String        @unique
    subtotal      Float
    tax           Float         @default(0)
    discount      Float         @default(0)
    total         Float
    amountPaid    Float
    change        Float         @default(0)
    paymentMethod String        // "cash", "card", "digital_wallet", etc.
    balanceId     Int?          // Reference to balance account
    cashierId     String?       // Employee who processed the sale
    notes         String?
    saleDate      DateTime      @default(now())
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt
    
    balanceAccount BalanceAccount? @relation(fields: [balanceId], references: [id], onDelete: SetNull)
    cashier       User?          @relation(fields: [cashierId], references: [id], onDelete: SetNull)
    items         POSSaleItem[]
    
    @@index([saleDate])
    @@index([saleNumber])
    @@index([cashierId])
}

model POSSaleItem {
    id       String  @id @default(cuid())
    saleId   String
    itemId   String
    quantity Int
    price    Float   // Price at time of sale
    subtotal Float   // quantity * price
    
    sale     POSSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
    item     POSItem @relation(fields: [itemId], references: [id])
    
    @@index([saleId])
    @@index([itemId])
}