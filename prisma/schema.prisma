// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum RoleType {
    EMPLOYEE
    MEMBER
}

enum PaymentStatus {
    SUCCESS
    PENDING
    FAILED
}

enum VoucherType {
    REFERRAL
    GENERAL
}

enum DiscountType {
    PERCENT
    CASH
}

enum PaymentValidationStatus {
    WAITING
    ACCEPTED
    DECLINED
}

enum FlowType {
    income
    outcome
    both
}

enum Gender {
    MALE
    FEMALE
    OTHER
}

model File {
    id           String   @id @default(uuid())
    bucket       String
    fileName     String   @unique
    originalName String
    createdAt    DateTime @default(now())
    size         Int
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id                 String       @id @default(cuid())
    name               String?
    email              String?      @unique
    emailVerified      DateTime?
    password           String?
    address            String?
    phone              String?
    birthDate          DateTime?
    idNumber           String?
    image              String?
    roles              Role[]
    memberships        Membership[] @relation("MembershipToUser")
    personalTrainer    PersonalTrainer[] @relation("PersonalTrainerToUser")
    accounts           Account[]
    sessions           Session[]
    posts              Post[]
    createdBy          String?
    createdUsers       User[]       @relation("UserCreatedBy")
    creator            User?        @relation("UserCreatedBy", fields: [createdBy], references: [id])
    createdMemberships Membership[] @relation("MembershipCreator")
    createdAt          DateTime     @default(now())
    updatedAt          DateTime     @updatedAt
    point              Int          @default(0)
    employee           Employee?    @relation("EmployeeToUser")
    memberRewards      MemberReward[]
    voucherClaims      VoucherClaim[]
    height             Float?
    weight             Float?
    gender             Gender?
}

model Class {
    id          String           @id @default(cuid())
    name        String
    limit       Int?
    trainerId   String
    schedule    DateTime
    duration    Int
    price       Float           @default(0)
    createdAt   DateTime         @default(now())
    updatedAt   DateTime         @updatedAt
    trainer     PersonalTrainer  @relation(fields: [trainerId], references: [id])
    registeredMembers ClassMember[]
    waitingList        ClassWaitingList[]
}

model ClassMember {
    id        String      @id @default(cuid())
    classId   String
    memberId  String
    class     Class       @relation(fields: [classId], references: [id])
    member    Membership  @relation(fields: [memberId], references: [id])
    joinedAt  DateTime    @default(now())
}

model ClassWaitingList {
    id        String      @id @default(cuid())
    classId   String
    memberId  String
    class     Class       @relation(fields: [classId], references: [id])
    member    Membership  @relation(fields: [memberId], references: [id])
    joinedAt  DateTime    @default(now())
}

model Membership {
    id            String         @id @default(cuid())
    userId        String         @unique
    user          User           @relation("MembershipToUser", fields: [userId], references: [id])
    registerDate  DateTime
    rfidNumber    String?
    isActive      Boolean        @default(false)
    createdBy     String?
    revokedAt     DateTime?
    creator       User?          @relation("MembershipCreator", fields: [createdBy], references: [id])
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt
    subscriptions Subscription[]
    registeredClasses ClassMember[]
    waitingClasses    ClassWaitingList[]
    trainerSessions   TrainerSession[]
    paymentValidations PaymentValidation[]
}

model Role {
    id          String           @id @default(cuid())
    name        String           @unique
    permissions RolePermission[]
    users       User[]
}

model Permission {
    id    String           @id @default(cuid())
    name  String           @unique
    roles RolePermission[]
}

model RolePermission {
    roleId       String
    permissionId String
    role         Role       @relation(fields: [roleId], references: [id])
    permission   Permission @relation(fields: [permissionId], references: [id])

    @@id([roleId, permissionId])
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model Subscription {
    id        String     @id @default(cuid())
    memberId  String
    trainerId String?
    packageId String
    member    Membership @relation(fields: [memberId], references: [id])
    package   Package   @relation(fields: [packageId], references: [id])
    trainer   PersonalTrainer? @relation(fields: [trainerId], references: [id])
    startDate DateTime
    endDate   DateTime?
    remainingSessions Int?
    payments  Payment[]
}

model Payment {
    id             String        @id @default(cuid())
    subscriptionId String
    subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
    status         PaymentStatus
    method         String
    totalPayment   Int
    createdAt      DateTime      @default(now())
}

model PersonalTrainer {
    id          String     @id @default(cuid())
    userId      String     @unique
    description String?
    expertise   String?
    image       String?
    isActive    Boolean    @default(true)
    createdAt   DateTime   @default(now())
    updatedAt   DateTime   @updatedAt
    class       Class[]
    
    user        User       @relation("PersonalTrainerToUser", fields: [userId], references: [id])
    subscriptions Subscription[]
    sessions      TrainerSession[]
    paymentValidations PaymentValidation[]
}

enum MembershipStatus {
    ACTIVE
    EXPIRED
    REVOKED
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    createdById String

    createdBy   User   @relation(fields: [createdById], references: [id])

    @@index([name])
}

model Package {
    id          String   @id @default(cuid())
    name        String
    description String?
    price       Float
    point       Int     @default(0)  // Points yang akan didapat user ketika membeli paket
    isActive    Boolean  @default(true)
    type        PackageType
    sessions    Int?        // only for PERSONAL_TRAINER type
    day         Int?        // only for GYM_MEMBERSHIP type
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    subscription Subscription[]
    paymentValidations PaymentValidation[]
}

enum PackageType {
    GYM_MEMBERSHIP
    PERSONAL_TRAINER
}

model TrainerSession {
    id          String   @id @default(cuid())
    trainerId   String
    memberId    String
    date        DateTime
    startTime   DateTime
    endTime     DateTime
    description String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    trainer     PersonalTrainer @relation(fields: [trainerId], references: [id])
    member      Membership      @relation(fields: [memberId], references: [id])

    @@map("trainer_sessions")
}

model Voucher {
    id            String       @id @default(cuid())
    name          String
    maxClaim      Int         // Maximum number of times this voucher can be claimed
    type          VoucherType
    discountType  DiscountType
    referralCode  String?     // Optional referral code, only used for REFERRAL type
    amount        Int         // Amount of discount (in percentage or cash value)
    isActive      Boolean     @default(true)
    expiryDate    DateTime?   // Optional expiry date for the voucher
    createdAt     DateTime    @default(now())
    updatedAt     DateTime    @updatedAt
    claims        VoucherClaim[]

    @@index([referralCode])
    @@index([type])
}

model VoucherClaim {
    id        String   @id @default(cuid())
    memberId  String
    voucherId String
    claimedAt DateTime @default(now())
    member    User     @relation(fields: [memberId], references: [id])
    voucher   Voucher  @relation(fields: [voucherId], references: [id])

    @@index([memberId])
    @@index([voucherId])
}

model PaymentValidation {
    id             String                  @id @default(cuid())
    memberId       String
    packageId      String
    trainerId      String?
    subsType       String // "gym" or "trainer"
    duration       Int    // days for gym, sessions for trainer
    totalPayment   Float
    paymentMethod  String // e.g., "direct_payment"
    filePath       String? // Path to the uploaded proof of payment
    paymentStatus  PaymentValidationStatus @default(WAITING)
    createdAt      DateTime                @default(now())
    updatedAt      DateTime                @updatedAt
    balanceId      Int?                    
    
    balanceAccount BalanceAccount?         @relation(fields: [balanceId], references: [id], onDelete: SetNull)
    member         Membership              @relation(fields: [memberId], references: [id])
    package        Package                 @relation(fields: [packageId], references: [id])
    trainer        PersonalTrainer?        @relation(fields: [trainerId], references: [id])
    @@index([memberId])
    @@index([paymentStatus])
}

model MemberReward {
    id        String   @id @default(cuid())
    memberId  String
    rewardId  String
    claimedAt DateTime @default(now())
    member    User     @relation(fields: [memberId], references: [id])
    reward    Reward   @relation(fields: [rewardId], references: [id])

    @@index([memberId])
    @@index([rewardId])
}

model Reward {
    id        String   @id @default(cuid())
    name      String
    iconName  String
    price     Int
    stock     Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    memberRewards MemberReward[]
}

model Employee {
    id          String    @id @default(cuid())
    userId      String    @unique
    position    String?
    department  String?
    image       String?
    isActive    Boolean   @default(true)
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    attendances Attendance[]

    user        User      @relation("EmployeeToUser", fields: [userId], references: [id])
}

model Attendance {
    id          String    @id @default(cuid())
    employeeId  String
    checkIn     DateTime
    checkOut    DateTime?
    date        DateTime  @default(now())
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    employee    Employee  @relation(fields: [employeeId], references: [id])

    @@index([date])
    @@index([employeeId])
}

model BalanceAccount {
    id               Int           @id @default(autoincrement())
    name             String
    account_number   String
    bankTransactions Transaction[] @relation("BankTransactions")
    paymentValidations PaymentValidation[]
}

model ChartAccount {
    id                   Int           @id @default(autoincrement())
    reff                 String
    name                 String
    type                 String
    flow                 FlowType
    accountTransactions  Transaction[] @relation("AccountTransactions")
}

model Transaction {
    id                 Int             @id @default(autoincrement())
    admin_id           Int
    bank_id            Int
    account_id         Int
    type               String
    file               String
    description        String
    transaction_date   DateTime
    transaction_number String
    amount             Float
    closed_at          DateTime?

    // Relations
    bank     BalanceAccount @relation("BankTransactions", fields: [bank_id], references: [id])
    account  ChartAccount   @relation("AccountTransactions", fields: [account_id], references: [id])
}

