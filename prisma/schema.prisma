generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum EnrollmentStatus {
    NOT_YET
    PENDING
    ENROLLED
    FAILED
}

enum RoleType {
    EMPLOYEE
    MEMBER
}

enum PaymentStatus {
    SUCCESS
    PENDING
    FAILED
    EXPIRED
    CANCELED
    CHALLENGED
    REFUNDED
    SETTLED
}

enum VoucherType {
    REFERRAL
    GENERAL
}

enum DiscountType {
    PERCENT
    CASH
}

enum PaymentValidationStatus {
    WAITING
    ACCEPTED
    DECLINED
}

enum FCMemberStatus {
    new
    contacted
    follow_up
    interested
    not_interested
    pending
    scheduled
    converted
    rejected
    inactive
}

enum FlowType {
    income
    outcome
    both
}

enum Gender {
    MALE
    FEMALE
    OTHER
}

enum SessionStatus {
    ENDED
    NOT_YET
    CANCELED
    ONGOING
}

enum FreezeMode {
    FIXED_DAYS
    UNTIL_UNFREEZE
}

enum FreezeOperationType {
    FREEZE
    UNFREEZE
}

// Purchase and Adjustment Enums
enum InventoryTransactionType {
    SALE              // Decrease from POS sale
    SALE_VOID         // Restore from voided/deleted sale
    PURCHASE_RECEIVE  // Increase from receiving purchase order
    ADJUSTMENT_IN     // Manual increase adjustment
    ADJUSTMENT_OUT    // Manual decrease adjustment
    RETURN            // Return from customer
    TRANSFER_IN       // Transfer from another location (future)
    TRANSFER_OUT      // Transfer to another location (future)
    INITIAL           // Initial stock count
}

enum PurchaseOrderStatus {
    DRAFT             // Order is being prepared
    PENDING           // Order submitted, awaiting supplier
    ORDERED           // Order confirmed by supplier
    PARTIALLY_RECEIVED // Some items received
    RECEIVED          // All items received
    CANCELLED         // Order cancelled
}

enum PurchaseOrderItemStatus {
    PENDING           // Not yet received
    PARTIALLY_RECEIVED // Some quantity received
    RECEIVED          // Full quantity received
    CANCELLED         // Item cancelled
}

model File {
    id           String   @id @default(uuid())
    bucket       String
    fileName     String   @unique
    originalName String
    createdAt    DateTime @default(now())
    size         Int
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id                 String            @id @default(cuid())
    name               String?
    email              String?           @unique
    emailVerified      DateTime?
    password           String?
    address            String?
    phone              String?
    birthDate          DateTime?
    idNumber           String?
    image              String?
    resetToken         String?           @unique
    resetTokenExpiry   DateTime?
    roles              Role[]
    memberships        Membership[]      @relation("MembershipToUser")
    personalTrainer    PersonalTrainer[] @relation("PersonalTrainerToUser")
    fc                 FC[]             @relation("FCToUser")
    accounts           Account[]
    sessions           Session[]
    posts              Post[]
    createdBy          String?
    createdUsers       User[]            @relation("UserCreatedBy")
    creator            User?             @relation("UserCreatedBy", fields: [createdBy], references: [id])
    createdMemberships Membership[]      @relation("MembershipCreator")
    createdFCs         FC[]             @relation("UserCreatedBy")
    createdAt          DateTime          @default(now())
    updatedAt          DateTime          @updatedAt
    point              Int               @default(0)
    employee           Employee?         @relation("EmployeeToUser")
    memberRewards      MemberReward[]
    voucherClaims      VoucherClaim[]
    height             Float?
    weight             Float?
    gender             Gender?
    posSales           POSSale[]
    trackingUsers      TrackingUser[]    @relation("TrackingUserToUser")
    aiRateLimits       AIRateLimit[]     @relation("UserAIRateLimit")
    aiRequestLogs      AIRequestLog[]    @relation("UserAIRequestLog")
    // upgradePackages    UpgradePackage[]  @relation("UpgradeCreatedBy")
    
    // Purchase and Adjustment relations
    inventoryTransactions   InventoryTransaction[] @relation("InventoryTransactionUser")
    createdPurchaseOrders   PurchaseOrder[]        @relation("PurchaseOrderCreator")
    updatedPurchaseOrders   PurchaseOrder[]        @relation("PurchaseOrderUpdater")
    priceHistoryChanges     POSItemPriceHistory[]  @relation("POSItemPriceHistoryUser")
    
    // Freeze operations performed by user
    performedFreezeOperations FreezeOperation[]    @relation("FreezeOperationPerformedBy")
    
    // Freeze transactions created by user
    createdTransactionFreezes TransactionFreeze[]  @relation("TransactionFreezeCreator")
    
    // API mutation logs
    logs                      Logs[]                @relation("UserLogs")
}

model Class {
    id                String             @id @default(cuid())
    name              String
    classTypeId       String?
    limit             Int?
    instructorName    String
    schedule          DateTime
    duration          Int
    price             Float              @default(0)
    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt
    
    classType         ClassType?         @relation(fields: [classTypeId], references: [id])
    registeredMembers ClassMember[]
    waitingList       ClassWaitingList[]
}

model ClassType {
    id          String @id @default(cuid())
    name        String @unique
    icon        String
    description String
    level       String // "Easy", "Medium", "Hard"
    isActive    Boolean @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    classes     Class[]
}

model ClassMember {
    id       String     @id @default(cuid())
    classId  String
    memberId String
    class    Class      @relation(fields: [classId], references: [id])
    member   Membership @relation(fields: [memberId], references: [id])
    joinedAt DateTime   @default(now())
}

model ClassWaitingList {
    id       String     @id @default(cuid())
    classId  String
    memberId String
    class    Class      @relation(fields: [classId], references: [id])
    member   Membership @relation(fields: [memberId], references: [id])
    joinedAt DateTime   @default(now())
}

model Membership {
    id                String             @id @default(cuid())
    userId            String             @unique
    user              User               @relation("MembershipToUser", fields: [userId], references: [id])
    registerDate      DateTime
    rfidNumber        String?
    isActive          Boolean            @default(false)
    createdBy         String?
    fcId              String?
    fc                FC?                @relation(fields: [fcId], references: [id])
    revokedAt         DateTime?
    creator           User?              @relation("MembershipCreator", fields: [createdBy], references: [id])
    createdAt         DateTime           @default(now())
    updatedAt         DateTime           @updatedAt
    subscriptions     Subscription[]
    registeredClasses ClassMember[]
    waitingClasses    ClassWaitingList[]
    trainerSessions   TrainerSession[]
    paymentValidations PaymentValidation[]
    attendanceMembers AttendanceMember[] @relation("AttendanceMemberToMembership")
    transfersFrom     SubscriptionTransferHistory[]
    freezeOperations  FreezeOperation[]  @relation("FreezeOperationMember")
}

model Role {
    id          String           @id @default(cuid())
    name        String           @unique
    permissions RolePermission[]
    users       User[]
}

model Permission {
    id    String           @id @default(cuid())
    name  String           @unique
    roles RolePermission[]
}

model RolePermission {
    roleId       String
    permissionId String
    role         Role       @relation(fields: [roleId], references: [id])
    permission   Permission @relation(fields: [permissionId], references: [id])

    @@id([roleId, permissionId])
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model Subscription {
    id                String           @id @default(cuid())
    memberId          String
    trainerId         String?
    packageId         String
    salesId           String?          // ID of the sales person (PersonalTrainer or FC)
    salesType         String?          // Type: "PersonalTrainer" or "FC"
    member            Membership       @relation(fields: [memberId], references: [id])
    package           Package          @relation(fields: [packageId], references: [id])
    trainer           PersonalTrainer? @relation(fields: [trainerId], references: [id])
    startDate         DateTime
    endDate           DateTime?
    remainingSessions Int?
    isActive          Boolean          @default(false)
    
    // Freeze state (existing)
    isFrozen          Boolean          @default(false)
    frozenAt          DateTime?
    freezeAtStart     Boolean?         @default(false)
    freezeDays        Int?
    
    // Freeze improvements (new)
    freezeMode        FreezeMode?
    remainingDays     Int?
    
    deletedAt         DateTime?        // Soft delete timestamp
    payments          Payment[]
    
      // Reminder tracking
    isReminder        Boolean          @default(false)   // sudah dikirim reminder atau belum
    reminderAt        DateTime?                        // kapan terakhir reminder dikirim
    reminderStage     Int?                             // tahap reminder (misal 1 = H-7, 2 = H-3, 3 = H-1)
    
    // Group subscription relations
    leadGroupSubscriptions GroupSubscription[]
    groupMembers      GroupMember[]
    
    // Upgrade relations
    upgradePackages   UpgradePackage[]
    
    // Freeze operations
    freezeOperations  FreezeOperation[]
    
    // Transfer history
    transferHistory   SubscriptionTransferHistory[]
}

model Payment {
    id             String           @id @default(cuid())
    subscriptionId    String
    subscription      Subscription     @relation(fields: [subscriptionId], references: [id])
    status            PaymentStatus
    method            String
    amount            Int?
    totalPayment      Int
    token             String?          // Dedicated field for payment gateway token
    tokenExpiry       DateTime?        // When the token expires
    orderReference    String?          @unique  // Used to track payments with the gateway
    gatewayResponse   Json?            // Store the complete gateway response
    paymentUrl        String?          // URL to payment page (if applicable)
    paidAt            DateTime?        // When the payment was completed
    deletedAt         DateTime?        // Soft delete timestamp
    createdAt         DateTime         @default(now())
    updatedAt         DateTime         @default(now())
    freezeOperationId String?
    freezeOperation   FreezeOperation? @relation(fields: [freezeOperationId], references: [id])
}

model PersonalTrainer {
    id          String   @id @default(cuid())
    userId      String   @unique
    description String?
    expertise   String?
    image       String?
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    // class       Class[]  // Removed: no longer a relation to Class

    user          User             @relation("PersonalTrainerToUser", fields: [userId], references: [id])
    subscriptions Subscription[]
    sessions      TrainerSession[]
    paymentValidations PaymentValidation[]

}

enum MembershipStatus {
    ACTIVE
    EXPIRED
    REVOKED
}

model Post {
    id          Int      @id @default(autoincrement())
    name        String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    createdById String

    createdBy User @relation(fields: [createdById], references: [id])

    @@index([name])
}

model Package {
    id           String         @id @default(cuid())
    name         String
    description  String?
    price        Float
    point        Int            @default(0) // Points yang akan didapat user ketika membeli paket
    isActive     Boolean        @default(true)
    type         PackageType
    sessions     Int? // only for PERSONAL_TRAINER type
    day          Int? // only for GYM_MEMBERSHIP type
    
    // Group package fields
    maxUsers     Int?           // Maximum users for group packages
    isGroupPackage Boolean      @default(false)
    groupPriceType GroupPriceType? // TOTAL or PER_PERSON
    
    createdAt    DateTime       @default(now())
    updatedAt    DateTime       @updatedAt
    subscription Subscription[]
    paymentValidations PaymentValidation[]
    groupSubscriptions GroupSubscription[]
    
    // Upgrade relations
    upgradeOldPackages UpgradePackage[] @relation("UpgradeOldPackage")
    upgradeNewPackages UpgradePackage[] @relation("UpgradeNewPackage")
}

enum PackageType {
    GYM_MEMBERSHIP
    PERSONAL_TRAINER
    GROUP_TRAINING
}

enum GroupPriceType {
    TOTAL      // Total price split among members
    PER_PERSON // Each person pays the full price
}

model TrainerSession {
    id          String   @id @default(cuid())
    trainerId   String
    memberId    String
    date        DateTime
    startTime   DateTime
    endTime     DateTime
    description String?
    status      String   @default("NOT_YET")
    exerciseResult String? // Optional path to the uploaded exercise result file
    attendanceCount Int?    @default(1) // Number of attendees for group sessions
    isGroup     Boolean  @default(false) // Whether this is a group session
    groupId     String?  // Reference to group subscription if applicable
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    trainer     PersonalTrainer @relation(fields: [trainerId], references: [id])
    member      Membership @relation(fields: [memberId], references: [id])
}

model Voucher {
    id           String         @id @default(cuid())
    name         String
    maxClaim     Int // Maximum number of times this voucher can be claimed
    type         VoucherType
    discountType DiscountType
    referralCode String? // Optional referral code, only used for REFERRAL type
    amount       Int // Amount of discount (in percentage or cash value)
    minimumPurchase Int?        @default(0) // Minimum purchase amount required to use this voucher
    allowStack   Boolean        @default(false) // Allow using multiple vouchers at the same time
    isActive     Boolean        @default(true)
    expiryDate   DateTime? // Optional expiry date for the voucher
    createdAt    DateTime       @default(now())
    updatedAt    DateTime       @updatedAt
    claims       VoucherClaim[]

    @@index([referralCode])
    @@index([type])
}

model VoucherClaim {
    id        String   @id @default(cuid())
    memberId  String
    voucherId String
    claimedAt DateTime @default(now())
    member    User     @relation(fields: [memberId], references: [id])
    voucher   Voucher  @relation(fields: [voucherId], references: [id])

    @@index([memberId])
    @@index([voucherId])
}

model PaymentValidation {
    id             String                  @id @default(cuid())
    memberId       String
    packageId      String
    trainerId      String?
    fcId           String?
    subsType       String // "gym" or "trainer"
    duration       Int    // days for gym, sessions for trainer
    sessions       Int?   // number of sessions for trainer package
    totalPayment   Float
    paymentMethod  String // e.g., "direct_payment"
    filePath       String? // Path to the uploaded proof of payment
    paymentStatus  PaymentValidationStatus @default(WAITING)
    startDate      DateTime?               // Start date for the membership/subscription
    freezeAtStart  Boolean?                @default(false)
    freezeDays     Int?
    createdAt      DateTime                @default(now())
    updatedAt      DateTime                @updatedAt
    balanceId      Int?                    
    balanceAccount BalanceAccount?         @relation(fields: [balanceId], references: [id], onDelete: SetNull)
    salesId        String?                 // ID of the sales person (PersonalTrainer or FC)
    salesType      String?                 // Type: "PersonalTrainer" or "FC"
    member         Membership              @relation(fields: [memberId], references: [id])
    package        Package                 @relation(fields: [packageId], references: [id])
    trainer        PersonalTrainer?        @relation(fields: [trainerId], references: [id])
    fc             FC?                     @relation(fields: [fcId], references: [id])
    @@index([memberId])
    @@index([paymentStatus])
}

model MemberReward {
    id        String   @id @default(cuid())
    memberId  String
    rewardId  String
    claimedAt DateTime @default(now())
    member    User     @relation(fields: [memberId], references: [id])
    reward    Reward   @relation(fields: [rewardId], references: [id])

    @@index([memberId])
    @@index([rewardId])
}

model Reward {
    id            String         @id @default(cuid())
    name          String
    iconName      String
    price         Int
    stock         Int
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt
    memberRewards MemberReward[]
}

model Employee {
    id              String           @id @default(cuid())
    userId          String           @unique
    position        String?
    department      String?
    image           String?
    fingerprintId   Int?            @unique
    rfidTag         String?         @unique
    isActive        Boolean         @default(true)
    enrollmentStatus EnrollmentStatus?
    deviceId        String?         // For tracking which device is enrolling
    createdAt       DateTime        @default(now())
    updatedAt       DateTime        @updatedAt
    attendances Attendance[]

    user User @relation("EmployeeToUser", fields: [userId], references: [id])
}

model Attendance {
    id         String    @id @default(cuid())
    employeeId String
    checkIn    DateTime
    checkOut   DateTime?
    deviceId  String? // Optional device ID for attendance tracking
    date       DateTime  @default(now())
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt

    employee Employee @relation(fields: [employeeId], references: [id])

    @@index([date])
    @@index([employeeId])
}

model BalanceAccount {
    id               Int           @id @default(autoincrement())
    name             String
    account_number   String
    initialBalance   Float         @default(0)
    lastBalance      Float         @default(0)
    totalTransaction Float         @default(0)
    bankTransactions Transaction[] @relation("BankTransactions")
    paymentValidations PaymentValidation[]
    posSales         POSSale[]
    periodClosings   BalanceAccountPeriodClosing[]
    transactionFreezes TransactionFreeze[]
}

model BalanceAccountPeriodClosing {
    id               Int            @id @default(autoincrement())
    balanceAccount   BalanceAccount @relation(fields: [balanceAccountId], references: [id])
    balanceAccountId Int

    startDate        DateTime
    endDate          DateTime

    initialBalance   Float          @default(0)
    totalDebits      Float          @default(0)
    totalCredits     Float          @default(0)
    closingBalance   Float          @default(0)

    closedAt         DateTime       @default(now())
    closedBy         String?

    @@unique([balanceAccountId, startDate, endDate])
}

model ChartAccount {
    id                  Int           @id @default(autoincrement())
    reff                String
    name                String
    type                String
    flow                FlowType
    accountTransactions Transaction[] @relation("AccountTransactions")
}

model Transaction {
    id                 Int       @id @default(autoincrement())
    bank_id            Int
    account_id         Int
    type               String
    file               String
    description        String
    transaction_date   DateTime
    transaction_number String
    amount             Float
    closed_at          DateTime?
    deleted_at         DateTime?

    // Relations
    bank    BalanceAccount @relation("BankTransactions", fields: [bank_id], references: [id])
    account ChartAccount   @relation("AccountTransactions", fields: [account_id], references: [id])
    purchaseOrders PurchaseOrder[]  // Purchase orders linked to this transaction
}

model AttendanceMember {
    id        String     @id @default(cuid())
    memberId  String
    checkin   DateTime
    checkout  DateTime?
    facilityDescription String?
    member    Membership @relation("AttendanceMemberToMembership", fields: [memberId], references: [id])

    @@index([memberId])
}

model FC {
    id          String   @id @default(cuid())
    userId      String   @unique
    referralCode String? @unique
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    createdBy   String?

    user          User             @relation("FCToUser", fields: [userId], references: [id])
    creator       User?            @relation("UserCreatedBy", fields: [createdBy], references: [id])
    paymentValidations PaymentValidation[]
    memberships   Membership[]
    fc_members    FcMember[]
}

// Email Configuration Models
enum EmailType {
    MEMBERSHIP_CONFIRMATION
    PAYMENT_RECEIPT
    PASSWORD_RESET
    SUBSCRIPTION_EXPIRY
    TRAINER_SESSION_REMINDER
}

enum EmailStatus {
    PENDING
    SENT
    FAILED
    BOUNCED
}

model EmailConfig {
    id              String   @id @default(cuid())
    name            String   @unique // e.g., "primary", "backup"
    host            String
    port            Int
    username        String
    password        String   // encrypted
    fromEmail       String
    fromName        String
    useTLS          Boolean  @default(true)
    useSSL          Boolean  @default(false)
    isActive        Boolean  @default(false)
    isDefault       Boolean  @default(false)
    
    // Template branding fields
    supportEmail    String?  // Contact email for email templates
    supportPhone    String?  // Contact phone for email templates
    logoUrl         String?  // Logo URL for email branding
    businessAddress String?  // Business address for templates
    currency        String?  @default("Rp") // Currency symbol for formatting
    
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    @@index([isActive])
    @@index([isDefault])
}

model EmailTemplate {
    id          String   @id @default(cuid())
    name        String   @unique
    type        EmailType
    subject     String
    htmlContent String   @db.Text
    textContent String?  @db.Text
    variables   Json     // Available template variables
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    emailLogs   EmailLog[]

    @@index([type])
    @@index([isActive])
}

model FcMember {
    id           String   @id @default(cuid())
    fc_id        String
    member_name  String
    member_phone String
    address      String?
    status       FCMemberStatus
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
    fc           FC       @relation(fields: [fc_id], references: [id])
    @@index([fc_id])
}

model EmailLog {
    id          String      @id @default(cuid())
    to          String
    subject     String
    templateId  String?
    status      EmailStatus @default(PENDING)
    errorMessage String?
    sentAt      DateTime?
    createdAt   DateTime    @default(now())
    
    template    EmailTemplate? @relation(fields: [templateId], references: [id])

    @@index([status])
    @@index([createdAt])
    @@index([to])
}

model Config {
    id        String   @id @default(cuid())
    key       String   @unique
    value     String
    category  String?  // Optional category for organizing configs
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([key])
    @@index([category])
}


enum DeviceStatus {
    ONLINE
    OFFLINE
    ERROR
    MAINTENANCE
}

model Device {
    id                 String       @id @default(cuid())
    name               String
    type               String       @default("ESP32") // Device type
    accessKey          String
    status             DeviceStatus @default(OFFLINE)
    isActive           Boolean      @default(true)
    lastSeen           DateTime?
    
    // WiFi Configuration
    configuredWifi     String?      // Currently configured WiFi SSID
    wifiStatus         String?      // WiFi connection status
    availableNetworks  String?      @db.Text // JSON string of available networks
    lastNetworkScan    DateTime?
    lastConfigured     DateTime?
    
    // Firmware Management
    firmwareVersion    String?      // Current firmware version
    availableFirmware  String?      // Available firmware version
    lastFirmwareUpdate DateTime?
    
    // Device Health
    batteryLevel       Int?         // Battery percentage (if applicable)
    signalStrength     Int?         // WiFi signal strength
    uptime             Int?         // Device uptime in seconds
    temperature        Float?       // Device temperature
    errorMessage       String?      // Last error message
    errorCount         Int          @default(0)
    
    // MQTT Configuration
    mqttConnected      Boolean      @default(false)
    lastMqttMessage    DateTime?
    mqttClientId       String?
    
    createdAt          DateTime     @default(now())
    updatedAt          DateTime     @updatedAt
    
    @@index([status])
    @@index([lastSeen])
}

// POS Models for Additional Items (Drinks, Snacks, etc.)
model POSCategory {
    id          String      @id @default(cuid())
    name        String      @unique
    description String?
    isActive    Boolean     @default(true)
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt
    
    items       POSItem[]
}

model POSItem {
    id          String      @id @default(cuid())
    name        String
    description String?
    price       Float
    cost        Float?      @default(0)
    stock       Int         @default(0)  // Keep for backward compatibility
    warehouseStock Int      @default(0)  // New: Stock in warehouse (gudang)
    showcaseStock  Int      @default(0)  // New: Stock in showcase (for sales)
    minStock    Int?        @default(0)
    categoryId  String
    isActive    Boolean     @default(true)
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt
    
    category    POSCategory @relation(fields: [categoryId], references: [id])
    saleItems   POSSaleItem[]
    
    // Purchase and Adjustment relations
    inventoryTransactions   InventoryTransaction[]
    purchaseOrderItems      PurchaseOrderItem[]
    priceHistory            POSItemPriceHistory[]
    
    @@index([categoryId])
    @@index([name])
}

model POSSale {
    id            String        @id @default(cuid())
    saleNumber    String        @unique
    subtotal      Float
    tax           Float         @default(0)
    discount      Float         @default(0)
    total         Float
    amountPaid    Float
    change        Float         @default(0)
    paymentMethod String        // "cash", "card", "digital_wallet", etc.
    balanceId     Int?          // Reference to balance account
    cashierId     String?       // Employee who processed the sale
    notes         String?
    saleDate      DateTime      @default(now())
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt
    
    balanceAccount BalanceAccount? @relation(fields: [balanceId], references: [id], onDelete: SetNull)
    cashier       User?          @relation(fields: [cashierId], references: [id], onDelete: SetNull)
    items         POSSaleItem[]
    
    @@index([saleDate])
    @@index([saleNumber])
    @@index([cashierId])
}

model POSSaleItem {
    id       String  @id @default(cuid())
    saleId   String
    itemId   String
    quantity Int
    price    Float   // Price at time of sale
    subtotal Float   // quantity * price
    
    sale     POSSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
    item     POSItem @relation(fields: [itemId], references: [id])
    
    @@index([saleId])
    @@index([itemId])
}

// Group subscription management
model GroupSubscription {
    id                String   @id @default(cuid())
    groupName         String?
    leadSubscriptionId String
    packageId         String
    totalMembers      Int      @default(1)
    maxMembers        Int
    status            GroupSubscriptionStatus @default(PENDING)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
    
    leadSubscription  Subscription @relation(fields: [leadSubscriptionId], references: [id])
    package           Package      @relation(fields: [packageId], references: [id])
    groupMembers      GroupMember[]
    
    @@index([leadSubscriptionId])
    @@index([packageId])
    @@index([status])
}

model GroupMember {
    id                  String @id @default(cuid())
    groupSubscriptionId String
    subscriptionId      String
    status              GroupMemberStatus @default(PENDING)
    joinedAt            DateTime @default(now())
    
    groupSubscription   GroupSubscription @relation(fields: [groupSubscriptionId], references: [id])
    subscription        Subscription @relation(fields: [subscriptionId], references: [id])
    
    @@unique([groupSubscriptionId, subscriptionId])
    @@index([groupSubscriptionId])
    @@index([subscriptionId])
}

enum GroupSubscriptionStatus {
    ACTIVE
    PENDING
    EXPIRED
    CANCELLED
}

enum GroupMemberStatus {
    ACTIVE
    PENDING
    REMOVED
}

// OCR Tracking Models
model TrackingUser {
    id          String   @id @default(cuid())
    userId      String
    composition Json     // Body composition data (weight, fat, muscle, etc.)
    segment     Json     // Body segment data (leg muscle, trunk fat, etc.)
    obesity     Json     // Obesity metrics (BMI, WHR, BMR, VFA, etc.)
    suggestion  Json     // AI suggestions (body type, ideal weight, diet recommendations)
    raw_text    String   @db.Text // Original OCR text
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    
    user        User     @relation("TrackingUserToUser", fields: [userId], references: [id])
    
    @@index([userId])
    @@index([createdAt])
}

// AI Rate Limiting Models
enum AIRequestType {
    BODY_COMPOSITION
    CALORIE_CALCULATOR
    GENERAL
}

model AIRateLimit {
    id           String        @id @default(cuid())
    userId       String
    requestType  AIRequestType
    dailyLimit   Int           @default(5)
    weeklyLimit  Int           @default(20)
    monthlyLimit Int           @default(50)
    isActive     Boolean       @default(true)
    createdAt    DateTime      @default(now())
    updatedAt    DateTime      @updatedAt
    
    user         User          @relation("UserAIRateLimit", fields: [userId], references: [id], onDelete: Cascade)
    
    @@unique([userId, requestType])
    @@index([userId])
    @@index([requestType])
}

model AIRequestLog {
    id             String        @id @default(cuid())
    userId         String
    requestType    AIRequestType
    endpoint       String
    success        Boolean
    errorMessage   String?
    tokenCount     Int?
    processingTime Int?          // in milliseconds
    userAgent      String?
    ipAddress      String?
    createdAt      DateTime      @default(now())
    
    user           User          @relation("UserAIRequestLog", fields: [userId], references: [id], onDelete: Cascade)
    
    @@index([userId])
    @@index([requestType])
    @@index([createdAt])
    @@index([userId, requestType, createdAt])
}

// Upgrade Package Model for tracking membership upgrades
model UpgradePackage {
    id               String       @id @default(cuid())
    subscriptionId   String
    oldPackageId     String
    newPackageId     String
    paymentProofPath String?
    createdBy        String
    createdAt        DateTime     @default(now())
    
    subscription     Subscription @relation(fields: [subscriptionId], references: [id])
    oldPackage       Package      @relation("UpgradeOldPackage", fields: [oldPackageId], references: [id])
    newPackage       Package      @relation("UpgradeNewPackage", fields: [newPackageId], references: [id])
    // createdByUser    User         @relation("UpgradeCreatedBy", fields: [createdBy], references: [id])
    
    @@index([subscriptionId, createdAt])
    @@index([oldPackageId])
    @@index([newPackageId])
}

// ============================================
// Freeze Pricing Models
// ============================================

model FreezePrice {
    id         String   @id @default(cuid())
    freezeDays Int      @unique
    price      Int
    isActive   Boolean  @default(true)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    freezeOperations FreezeOperation[]
}

model TransactionFreeze {
    id               String   @id @default(cuid())
    balanceAccountId Int
    amount           Int
    description      String?
    createdBy        String
    createdAt        DateTime @default(now())

    balanceAccount   BalanceAccount @relation(fields: [balanceAccountId], references: [id])
    creator          User           @relation("TransactionFreezeCreator", fields: [createdBy], references: [id])
    freezeOperations FreezeOperation[]

    @@index([balanceAccountId])
    @@index([createdBy])
    @@index([createdAt])
}

model FreezeOperation {
    id                  String              @id @default(cuid())
    subscriptionId      String
    memberId            String              // Track which member this freeze operation is for
    freezePriceId       String
    transactionFreezeId String?
    operationType       FreezeOperationType
    freezeDays          Int
    price               Int
    performedAt         DateTime            @default(now())
    performedById       String

    subscription      Subscription         @relation(fields: [subscriptionId], references: [id])
    member            Membership           @relation("FreezeOperationMember", fields: [memberId], references: [id])
    freezePrice       FreezePrice          @relation(fields: [freezePriceId], references: [id])
    transactionFreeze TransactionFreeze?   @relation(fields: [transactionFreezeId], references: [id])
    performedBy       User                 @relation("FreezeOperationPerformedBy", fields: [performedById], references: [id])
    payments          Payment[]
}

// ============================================
// Purchase and Adjustment Models
// ============================================

// Audit trail for all stock movements
model InventoryTransaction {
    id              String                   @id @default(cuid())
    itemId          String
    type            InventoryTransactionType
    quantity        Int                      // Positive for increase, negative for decrease
    quantityBefore  Int                      // Stock before transaction
    quantityAfter   Int                      // Stock after transaction
    referenceType   String?                  // "POSSale", "PurchaseOrder", "Adjustment"
    referenceId     String?                  // ID of the reference record
    reason          String?                  // Reason for adjustment
    note            String?
    stockType       String?                  // "warehouse" or "showcase" - which stock was affected
    userId          String                   // Who performed the action
    idempotencyKey  String?                  @unique // For preventing duplicate transactions
    createdAt       DateTime                 @default(now())
    
    item            POSItem                  @relation(fields: [itemId], references: [id])
    user            User                     @relation("InventoryTransactionUser", fields: [userId], references: [id])
    
    @@index([itemId])
    @@index([type])
    @@index([referenceType, referenceId])
    @@index([createdAt])
    @@index([userId])
}

// Vendor/Supplier information
model Supplier {
    id              String          @id @default(cuid())
    name            String
    code            String?         @unique // Supplier code
    contactName     String?
    email           String?
    phone           String?
    address         String?
    notes           String?
    isActive        Boolean         @default(true)
    createdAt       DateTime        @default(now())
    updatedAt       DateTime        @updatedAt
    
    purchaseOrders  PurchaseOrder[]
    
    @@index([name])
    @@index([isActive])
}

// Purchase orders for restocking
model PurchaseOrder {
    id              String              @id @default(cuid())
    orderNumber     String              @unique
    supplierId      String?
    status          PurchaseOrderStatus @default(DRAFT)
    orderDate       DateTime?
    expectedDate    DateTime?
    receivedDate    DateTime?
    subtotal        Float               @default(0)
    tax             Float               @default(0)
    discount        Float               @default(0)
    total           Float               @default(0)
    notes           String?
    transactionId   Int?                // Link to accounting Transaction
    createdBy       String
    updatedBy       String?
    createdAt       DateTime            @default(now())
    updatedAt       DateTime            @updatedAt
    
    supplier        Supplier?           @relation(fields: [supplierId], references: [id])
    transaction     Transaction?        @relation(fields: [transactionId], references: [id])
    creator         User                @relation("PurchaseOrderCreator", fields: [createdBy], references: [id])
    updater         User?               @relation("PurchaseOrderUpdater", fields: [updatedBy], references: [id])
    items           PurchaseOrderItem[]
    
    @@index([status])
    @@index([supplierId])
    @@index([orderDate])
    @@index([createdBy])
}

// Items in a purchase order
model PurchaseOrderItem {
    id                  String                  @id @default(cuid())
    purchaseOrderId     String
    itemId              String
    quantity            Int                     // Ordered quantity
    receivedQuantity    Int                     @default(0) // Received so far
    unitCost            Float                   // Cost per unit
    subtotal            Float                   // quantity * unitCost
    status              PurchaseOrderItemStatus @default(PENDING)
    notes               String?
    createdAt           DateTime                @default(now())
    updatedAt           DateTime                @updatedAt
    
    purchaseOrder       PurchaseOrder           @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
    item                POSItem                 @relation(fields: [itemId], references: [id])
    
    @@index([purchaseOrderId])
    @@index([itemId])
    @@index([status])
}

// Track price changes for POS items
model POSItemPriceHistory {
    id              String      @id @default(cuid())
    itemId          String
    oldPrice        Float
    newPrice        Float
    oldCost         Float?
    newCost         Float?
    reason          String?
    changedBy       String
    effectiveFrom   DateTime    @default(now())
    createdAt       DateTime    @default(now())
    
    item            POSItem     @relation(fields: [itemId], references: [id])
    user            User        @relation("POSItemPriceHistoryUser", fields: [changedBy], references: [id])
    
    @@index([itemId])
    @@index([effectiveFrom])
    @@index([changedBy])
}

// ============================================
// Subscription Transfer History
// ============================================

model SubscriptionTransferHistory {
    id               String     @id @default(cuid())
    subscriptionId   String
    transferredPoint Int
    fromMemberId     String
    fromMemberName   String
    amount           Float
    file             String?
    reason           String?
    isCancelled      Boolean    @default(false)
    cancelledAt      DateTime?
    cancelledBy      String?
    cancelReason     String?
    createdAt        DateTime   @default(now())
    updatedAt        DateTime   @updatedAt
    
    subscription     Subscription @relation(fields: [subscriptionId], references: [id])
    fromMember       Membership   @relation(fields: [fromMemberId], references: [id])
    
    @@index([subscriptionId])
    @@index([fromMemberId])
    @@index([createdAt])
    @@index([isCancelled])
}

// ============================================
// API Mutation Logs Table
// ============================================

model Logs {
    id           String   @id @default(cuid())
    endpoint     String   // API endpoint name (e.g., "member.create", "subscription.update")
    method       String   // HTTP-like method: POST, PUT, PATCH, DELETE
    userId       String?  // User who made the request (if authenticated)
    // userName     String?
    // description String?
    requestData  Json?    // Input parameters passed to the mutation
    responseData Json?    // Response data returned (optional)
    ipAddress    String?  // IP address of the requester
    userAgent    String?  // Browser/client user agent
    success      Boolean  @default(true) // Whether the operation succeeded
    errorMessage String?  // Error message if operation failed
    duration     Int?     // Duration in milliseconds (optional)
    createdAt    DateTime @default(now())
    
    // Relations
    user         User?    @relation("UserLogs", fields: [userId], references: [id])
    
    // Indexes for efficient querying
    @@index([endpoint])
    @@index([userId])
    @@index([createdAt])
    @@index([success])
    @@index([endpoint, createdAt])
}