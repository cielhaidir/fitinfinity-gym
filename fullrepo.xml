                                    if (referralCode) {
                                        claimVoucherMutation.mutateAsync({ referralCode });
                                    }
                                }}
                            >
                                Apply
                            </Button>
                        </div>
                    </div>

                    {/* Remove Voucher Button */}
                    {currentVoucher && (
                        <Button
                            variant="destructive"
                            className="w-full"
                            onClick={removeVoucher}
                        >
                            <X className="mr-2 h-4 w-4" />
